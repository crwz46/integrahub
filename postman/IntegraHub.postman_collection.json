{
	"info": {
		"name": "IntegraHub API",
		"description": "Enterprise API Integration Gateway — Connect, Orchestrate, Monitor\n\n## Authentication\n\nThis collection uses OAuth2 Client Credentials flow.\n1. Create an integration via `POST /integrations` to get `client_id` and `client_secret`\n2. Or set `client_id` and `client_secret` in the environment variables\n3. The pre-request script will auto-fetch a token before each request\n\n## Base URL\n\nLocal: http://localhost:8000\nDocker: http://localhost:8000",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "integrahub"
	},
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints — OAuth2 Client Credentials & API Keys",
			"item": [
				{
					"name": "Get Access Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.collectionVariables.set('token', jsonData.access_token);",
									"console.log('Token set: ' + jsonData.access_token.substring(0, 20) + '...');"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"client_id\": \"{{client_id}}\",\n    \"client_secret\": \"{{client_secret}}\",\n    \"grant_type\": \"client_credentials\"\n}"
						},
						"url": {"raw": "{{base_url}}/auth/token", "host": ["{{base_url}}"], "path": ["auth", "token"]}
					}
				},
				{
					"name": "Create API Key",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": "My API Key",\n    \"scopes\": [\"integrations:read\", \"integrations:write\", \"jobs:read\", \"jobs:write\"]\n}"
						},
						"url": {"raw": "{{base_url}}/auth/api-keys", "host": ["{{base_url}}"], "path": ["auth", "api-keys"]}
					}
				},
				{
					"name": "List API Keys",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/auth/api-keys", "host": ["{{base_url}}"], "path": ["auth", "api-keys"]}
					}
				}
			]
		},
		{
			"name": "Integrations",
			"description": "Manage ATS/HRIS integrations — CRUD + test connection",
			"item": [
				{
					"name": "List Providers",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/integrations/providers/list", "host": ["{{base_url}}"], "path": ["integrations", "providers", "list"]}
					}
				},
				{
					"name": "Create Integration",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": "Production Workday",\n    \"provider\": \"workday\",\n    \"api_base_url\": \"https://api.workday.com/v1\",\n    \"api_version\": \"v1\",\n    \"config\": {\n        \"tenant\": \"acme_corp\",\n        \"rate_limit\": 100\n    }\n}"
						},
						"url": {"raw": "{{base_url}}/integrations", "host": ["{{base_url}}"], "path": ["integrations"]}
					}
				},
				{
					"name": "List Integrations",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/integrations", "host": ["{{base_url}}"], "path": ["integrations"]}
					}
				},
				{
					"name": "Get Integration",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/integrations/{{integration_id}}", "host": ["{{base_url}}"], "path": ["integrations", "{{integration_id}}"]}
					}
				},
				{
					"name": "Update Integration",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name": "Updated Workday",\n    \"config\": {\n        \"rate_limit\": 200\n    }\n}"
						},
						"url": {"raw": "{{base_url}}/integrations/{{integration_id}}", "host": ["{{base_url}}"], "path": ["integrations", "{{integration_id}}"]}
					}
				},
				{
					"name": "Test Connection",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/integrations/{{integration_id}}/test", "host": ["{{base_url}}"], "path": ["integrations", "{{integration_id}}", "test"]}
					}
				},
				{
					"name": "Delete Integration",
					"request": {
						"method": "DELETE",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/integrations/{{integration_id}}", "host": ["{{base_url}}"], "path": ["integrations", "{{integration_id}}"]}
					}
				}
			]
		},
