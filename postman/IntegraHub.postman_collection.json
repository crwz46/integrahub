							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"integration_id\": \"{{integration_id}}\",\n    \"payload\": {\n        \"title\": \"Senior Backend Engineer\",\n        \"location\": \"Jakarta\",\n        \"department\": \"Engineering\",\n        \"employment_type\": \"full-time\"\n    },\n    \"priority\": 0\n}"
						},
