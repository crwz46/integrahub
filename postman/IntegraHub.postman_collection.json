						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/jobs/{{job_id}}/retry", "host": ["{{base_url}}"], "path": ["jobs", "{{job_id}}", "retry"]}
					}
