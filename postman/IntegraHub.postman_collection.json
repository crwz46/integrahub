							{"key": "Authorization", "value": "Bearer {{token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"url\": \"https://hooks.example.com/integrahub\",\n    \"events\": [\n        \"job.submitted\",\n        \"job.completed\",\n        \"job.failed\",\n        \"status.changed\"\n    ],\n    \"description\": \"Production webhook receiver\"\n}"
						},
						"url": {"raw": "{{base_url}}/webhooks/register", "host": ["{{base_url}}"], "path": ["webhooks", "register"]}
					}
				},
				{
					"name": "List Subscriptions",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/webhooks/subscriptions", "host": ["{{base_url}}"], "path": ["webhooks", "subscriptions"]}
					}
