				{
					"name": "Queue Stats",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/jobs/stats/queue", "host": ["{{base_url}}"], "path": ["jobs", "stats", "queue"]}
					}
				}
			]
		},
		{
