						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{base_url}}/files/download/{{file_id}}", "host": ["{{base_url}}"], "path": ["files", "download", "{{file_id}}"]}
