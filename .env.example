APP_NAME=IntegraHub
APP_VERSION=1.0.0
DEBUG=true

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Webhook
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_BASE_DELAY_SECONDS=2
WEBHOOK_SIGNATURE_HEADER=x-integrahub-signature

# File Storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=10
PRESIGNED_URL_EXPIRY_MINUTES=30

# Queue
QUEUE_MAX_RETRIES=3
QUEUE_POLL_INTERVAL_SECONDS=5

# Data
DATA_PATH=./data
